# -----------------------------------------------------------------------------
# TicketFlow TI - Plantilla de Variables de Entorno
# Copia este archivo como '.env' y completa con tus credenciales.
# ¡NUNCA expongas tus claves reales en el control de versiones (Git)!
# -----------------------------------------------------------------------------

# 1. Base de Datos (Drizzle & Supabase / Postgres)
# - En Vercel (Producción) usar el puerto del Pooler de transacciones (Supabase: 6543)
# - En Local usar conexión directa (puerto 5432) o docker local
DATABASE_URL="postgresql://usuario:contraseña@servidor:puerto/nombre_db"

# 2. Seguridad & Sesiones
# - ORIGIN es requerido en producción para protección de CSRF en SvelteKit (ej: https://tu-app.vercel.app)
ORIGIN="http://localhost:5173"
# - JWT_SECRET: Clave de alta entropía de 32+ caracteres para firmar tokens JWT de sesión
JWT_SECRET="generar-clave-segura-de-alta-entropia-32-caracteres"

# 3. Credenciales del Administrador Inicial (Semilla)
# - Se utilizarán al correr 'pnpm db:seed' para crear la primera cuenta con rol ADMIN
ADMIN_USER="admin"
ADMIN_PASS="cambiar-por-una-contraseña-segura-en-produccion"
ADMIN_EMAIL="admin@ticketflow.com"

# 4. Configuración SMTP para Envío de Correo (Gmail / Brevo)
# - En Gmail requiere activar "Contraseñas de aplicación" en tu cuenta Google
GMAIL_USER="tu-correo@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# 5. Almacenamiento en la Nube (Cloudinary)
# - Requerido para almacenar archivos adjuntos y capturas de pantalla de los tickets
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
