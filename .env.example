# ==============================================================================
#                 TICKETFLOW TI - ARCHIVO DE PLANTILLA (.env.example)
# ==============================================================================
# INSTRUCCIONES:
# Copia este archivo a un nuevo archivo llamado '.env' e introduce tus credenciales
# reales. NUNCA subas el archivo '.env' real al repositorio de Git.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BASE DE DATOS (Drizzle ORM & PostgreSQL)
# ------------------------------------------------------------------------------
# [DESARROLLO LOCAL]: Conexión a tu base de datos de desarrollo
DATABASE_URL="postgres://usuario:contraseña@localhost:5432/nombre_db"

# [PRODUCCIÓN SUPABASE]: URL del Pooler de transacciones (Puerto 6543)
DATABASE_URL_PROD="postgresql://postgres.[ID_PROYECTO]:[CONTRASENA]@aws-1-us-east-2.pooler.supabase.com:6543/postgres"

# ------------------------------------------------------------------------------
# 2. SEGURIDAD Y NÚCLEO DE LA APLICACIÓN
# ------------------------------------------------------------------------------
# ORIGIN: URL base para protección contra CSRF de SvelteKit.
ORIGIN="http://localhost:5173"

# JWT_SECRET: Token criptográfico aleatorio de 32 bytes codificado en Base64.
# Puedes generar uno nuevo ejecutando: openssl rand -base64 32
JWT_SECRET=""

# ------------------------------------------------------------------------------
# 3. CREDENCIALES DEL ADMINISTRADOR INICIAL (Inicialización mediante db:seed)
# ------------------------------------------------------------------------------
# Credenciales del super-administrador inicial que se crearán al correr el seed.
ADMIN_USER="Admin"
ADMIN_PASS="Admin123"
ADMIN_EMAIL="admin@ticketflow.com"

# ------------------------------------------------------------------------------
# 4. SERVICIO DE CORREO SALIENTE (SMTP / Alertas e Incidencias)
# ------------------------------------------------------------------------------
# Correo electrónico del remitente (ej: Gmail)
GMAIL_USER="tu-correo@gmail.com"

# Contraseña de aplicación generada en la configuración de seguridad de Google.
# NUNCA ingreses la contraseña real de tu cuenta personal aquí.
GMAIL_APP_PASSWORD=""

# ------------------------------------------------------------------------------
# 5. ALMACENAMIENTO DE MEDIOS (Cloudinary / Capturas y Adjuntos de Tickets)
# ------------------------------------------------------------------------------
# Credenciales de Cloudinary para la carga y renderizado de imágenes.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
